# Public HTTPS host for ONLYOFFICE Docs, without https://
ONLYOFFICE_PUBLIC_HOST=office.example.ru

# Pin the image; update deliberately after compatibility testing.
ONLYOFFICE_IMAGE=onlyoffice/documentserver:8.3.0

# Generate a unique secret with at least 32 characters. Do not commit the real value.
ONLYOFFICE_JWT_SECRET=
