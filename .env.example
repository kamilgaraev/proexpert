APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info
LOG_API_LEVEL=warning
LOG_API_BODIES=false
LOG_AUTH_LEVEL=warning
LOG_DATABASE_LEVEL=warning
LOG_REDIS_LEVEL=warning
LOG_ACCESS_DAYS=30
LOG_API_DAYS=14
LOG_AUDIT_DAYS=365
LOG_BUSINESS_DAYS=90
LOG_DATABASE_DAYS=14
LOG_DEPRECATIONS_DAYS=14
LOG_REDIS_DAYS=14
LOG_SECURITY_DAYS=180
LOG_TECHNICAL_DAYS=30

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

RESEND_KEY=
DADATA_API_KEY=
DADATA_SECRET_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VIDEO_MONITORING_MEDIA_DRIVER=none
VIDEO_MONITORING_MEDIA_TIMEOUT=5
VIDEO_MONITORING_MEDIA_VERIFY_TLS=true
VIDEO_MONITORING_PREFERRED_LIVE_PROTOCOL=webrtc
VIDEO_MONITORING_AUTOFILL_PLAYBACK_URL=false
VIDEO_MONITORING_MEDIAMTX_MANAGE_PATHS=false
VIDEO_MONITORING_MEDIAMTX_API_BASE_URL=
VIDEO_MONITORING_MEDIAMTX_API_TOKEN=
VIDEO_MONITORING_MEDIAMTX_PATH_PREFIX=prohelper
VIDEO_MONITORING_MEDIAMTX_SOURCE_ON_DEMAND=true
VIDEO_MONITORING_MEDIAMTX_WEBRTC_URL=
VIDEO_MONITORING_MEDIAMTX_HLS_URL=

AI_ASSISTANT_ENABLED=true
LLM_PROVIDER=timeweb

TIMEWEB_AI_API_KEY=
TIMEWEB_AI_BASE_URI=https://api.timeweb.ai/v1
TIMEWEB_AI_MODEL=gemini/gemini-3.1-flash-lite
TIMEWEB_AI_MAX_TOKENS=2000
TIMEWEB_AI_TEMPERATURE=0.7
TIMEWEB_AI_TIMEOUT=25
TIMEWEB_AI_DEFAULT_PROFILE=assistant
TIMEWEB_AI_ASSISTANT_MODELS=gemini/gemini-3.1-flash-lite,gemini/gemini-2.5-flash
TIMEWEB_AI_JSON_MODELS=gemini/gemini-3.1-flash-lite,gemini/gemini-2.5-flash-lite
TIMEWEB_AI_FAST_MODELS=gemini/gemini-2.5-flash-lite,gemini/gemini-3.1-flash-lite
TIMEWEB_AI_PREMIUM_MODELS=anthropic/claude-4.6-sonnet,gemini/gemini-3.1-pro-preview
TIMEWEB_AI_ASSISTANT_TIMEOUT=25
TIMEWEB_AI_JSON_TIMEOUT=20
TIMEWEB_AI_FAST_TIMEOUT=12
TIMEWEB_AI_PREMIUM_TIMEOUT=35

AI_RAG_EMBEDDING_PROVIDER=timeweb
AI_RAG_EMBEDDING_MODEL=openai/text-embedding-3-large
AI_RAG_EMBEDDING_DIMENSIONS=256
AI_RAG_EMBEDDING_BASE_URI=https://api.timeweb.ai/v1
AI_RAG_EMBEDDING_API_KEY=

ESTIMATE_GENERATION_OCR_PROVIDER=timeweb
ESTIMATE_GENERATION_OCR_API_KEY=
ESTIMATE_GENERATION_OCR_BASE_URI=https://api.timeweb.ai/v1
ESTIMATE_GENERATION_OCR_MODEL=gemini/gemini-3.1-flash-lite
ESTIMATE_GENERATION_OCR_MODELS=gemini/gemini-3.1-flash-lite,gemini/gemini-3.1-flash,openai/gpt-5-mini
ESTIMATE_GENERATION_OCR_PDF_MODELS=openai/gpt-5-mini,openai/gpt-5-nano
ESTIMATE_GENERATION_OCR_MAX_TOKENS=4096
ESTIMATE_GENERATION_OCR_IMAGE_DETAIL=high
