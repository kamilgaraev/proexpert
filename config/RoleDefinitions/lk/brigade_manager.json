  "system_permissions": [
    "profile.view",
    "profile.edit"
  ],
  "module_permissions": {
    "brigades": [
      "brigades.view",
      "brigades.profile.view",
      "brigades.profile.edit",
      "brigades.members.view",
      "brigades.members.edit",
      "brigades.documents.view",
      "brigades.documents.edit",
      "brigades.invitations.view",
      "brigades.invitations.respond",
