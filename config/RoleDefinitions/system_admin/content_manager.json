    "system_admin.blog.categories.manage",
    "system_admin.blog.tags.manage",
    "system_admin.blog.media.view",
    "system_admin.blog.media.upload",
    "system_admin.blog.media.manage",
    "system_admin.blog.media.delete",
    "system_admin.blog.comments.moderate",
    "system_admin.blog.seo.manage",
    "system_admin.blog.revisions.view",
    "system_admin.blog.revisions.restore",
    "system_admin.blog.preview.view",
